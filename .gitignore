# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
kanban-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

.expert/

.mcp.json

TOKENS

.stride_auth.md
.stride-hook.log
.stride-env-cache
.stride-changed-files.json
priv/repo/seed_metrics_data.exs
package.json
package-lock.json
node_modules

stride/
!lib/mix/tasks/stride/
!lib/mix/tasks/stride/**
stride-copilot/
stride-gemini/
stride-ideation/
stride-copilot-ideation/
stride-codex-ideation/
stride-gemini-ideation/
stride-marketplace/
stride-opencode/
stride-opencode-ideation/
stride-codex/
stride-pi/
stride-lite/
stride-lite-copilot/
stride-security-review/
stride-security-review-copilot/
security-review/

# Per-developer Claude Code permission allow-list. Untracked so each
# contributor maintains their own narrow allow-list without coupling the
# repo's security posture to one developer's workflow.
.claude/settings.local.json

# Editor/IDE backup files. These accumulate accidentally, duplicate
# source code in places auditors and grep won't easily find, and have
# leaked credentials in other Phoenix projects' commit histories.
*.backup
*.bak

docs/blog/
.stride/
design_handoff_stride/
