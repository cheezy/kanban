<Layouts.app flash={@flash} current_scope={@current_scope} board={@board}>
  <:breadcrumbs>
    <.link navigate={~p"/boards"} style="color: var(--ink-3); text-decoration: none;">
      {gettext("Workspace")}
    </.link>
    <span style="color: var(--ink-4);">/</span>
    <.link navigate={~p"/boards"} style="color: var(--ink-3); text-decoration: none;">
      {gettext("Boards")}
    </.link>
    <span style="color: var(--ink-4);">/</span>
    <span style="display: inline-flex; align-items: center; gap: 6px;">
      <BoardHeader.identifier_badge board={@board} size={18} />
      <span style="color: var(--ink); font-weight: 500;">{@board.name}</span>
      <BoardHeader.ai_pill :if={Map.get(@board, :ai_optimized_board, false)} />
    </span>
  </:breadcrumbs>

  <:actions>
    <.link
      :if={@user_access == :owner and not @board.ai_optimized_board}
      patch={~p"/boards/#{@board}/columns/new"}
      class="btn btn-xs btn-ghost"
    >
      {gettext("New Column")}
    </.link>
  </:actions>

  <BoardHeader.board_header board={@board} />
  <BoardTabs.board_tabs
    board={@board}
    active={:board}
    owner?={@is_owner}
    can_modify?={@can_modify}
  />
  <GoalsStrip.goals_strip
    :if={assigns[:goals] not in [nil, []]}
    goals={@goals || []}
    board={@board}
  />

  <div class="mx-auto max-w-[1920px] px-2 pt-2 pb-2 sm:px-3 lg:px-4">
    <div
      id="undismissed_messages"
      phx-update="stream"
      aria-live="polite"
      class="mt-4 space-y-2"
    >
      <div
        :for={{dom_id, message} <- @streams.undismissed_messages}
        id={dom_id}
        role="alert"
        class="alert alert-info shadow-sm"
      >
        <.icon name="hero-megaphone" class="h-6 w-6 shrink-0" />
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold">{message.title}</h3>
          <p class="text-sm whitespace-pre-wrap">{message.body}</p>
        </div>
        <button
          type="button"
          phx-click="dismiss_message"
          phx-value-id={message.id}
          aria-label={gettext("Dismiss message")}
          class="btn btn-sm btn-ghost"
        >
          <.icon name="hero-x-mark" class="h-5 w-5" />
        </button>
      </div>
    </div>

    <%= if is_nil(@user_access) do %>
      <div class="mt-4 mb-2 p-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/30 dark:to-indigo-900/30 border border-blue-200 dark:border-blue-800 rounded-lg shadow-sm">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0">
            <.icon
              name="hero-information-circle"
              class="h-6 w-6 text-blue-600 dark:text-blue-400"
            />
          </div>
          <div class="flex-1">
            <p class="text-sm font-medium text-blue-900 dark:text-blue-100">
              {gettext("You are viewing this board in read-only mode")}
            </p>
            <p class="text-xs text-blue-700 dark:text-blue-300 mt-0.5">
              {gettext(
                "This board is shared publicly. You can view all tasks but cannot make any changes."
              )}
            </p>
          </div>
        </div>
      </div>
    <% end %>

    <div class="mt-2">
      <%= if !@has_columns do %>
        <div class="p-12 bg-gradient-to-br from-base-100 to-base-200 rounded-xl border-2 border-dashed border-base-300 shadow-sm">
          <div class="text-center max-w-md mx-auto">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gradient-to-br from-blue-100 to-purple-100 mb-6">
              <.icon name="hero-queue-list" class="h-10 w-10 text-blue-600" />
            </div>
            <h2 class="text-2xl font-bold text-base-content mb-2">{gettext("No columns yet")}</h2>
            <p class="text-base text-base-content opacity-70 mb-8 leading-relaxed">
              {gettext("Get started by creating columns for your board.")}
            </p>
            <div :if={@user_access == :owner and not @board.ai_optimized_board}>
              <.link patch={~p"/boards/#{@board}/columns/new"}>
                <.button>{gettext("Create your first column")}</.button>
              </.link>
            </div>
          </div>
        </div>
      <% else %>
        <div
          class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory md:snap-none"
          id="columns"
          phx-update="stream"
          phx-hook="ColumnSortable"
          data-responsive-columns="true"
        >
          <div
            :for={{id, column} <- @streams.columns}
            id={id}
            class="snap-start shrink-0 w-[calc(100vw-2rem)] md:w-auto md:flex-1 md:min-w-[256px] md:shrink bg-gradient-to-br from-base-200 to-base-300/80 rounded-xl p-4 shadow-sm border border-base-300/50"
            data-column-id={column.id}
          >
            <% all_tasks = Map.get(@tasks_by_column, column.id, []) %>
            <% task_count = Enum.count(all_tasks, &(&1.type in [:work, :defect])) %>
            <% total_tasks = length(all_tasks) %>
            <% at_limit = column.wip_limit > 0 and task_count >= column.wip_limit %>
            <% over_limit = column.wip_limit > 0 and task_count > column.wip_limit %>
            <div class="flex items-start justify-between mb-2 group">
              <%= if @user_access == :owner and not @board.ai_optimized_board do %>
                <div class="flex items-center gap-2 column-drag-handle cursor-grab active:cursor-grabbing mr-2 opacity-40 group-hover:opacity-100 transition-opacity">
                  <.icon name="hero-bars-3" class="h-5 w-5 text-base-content" />
                </div>
              <% end %>
              <div class="flex-1">
                <ColumnHeader.column_header
                  column={column}
                  count={task_count}
                  new_task_path={
                    if @can_modify and not at_limit,
                      do: ~p"/boards/#{@board}/columns/#{column}/tasks/new"
                  }
                />
                <%= if over_limit do %>
                  <div
                    title={gettext("WIP limit exceeded")}
                    class="mt-2 flex items-center gap-1.5 text-xs"
                  >
                    <.icon
                      name="hero-exclamation-triangle-solid"
                      class="h-3.5 w-3.5 text-red-600"
                    />
                    <span class="text-red-700 dark:text-red-400">
                      {gettext("WIP limit exceeded")}
                    </span>
                  </div>
                <% end %>
              </div>
              <%= if @user_access == :owner and not @board.ai_optimized_board do %>
                <div class="flex gap-1.5">
                  <.link
                    patch={~p"/boards/#{@board}/columns/#{column}/edit"}
                    aria-label={gettext("Edit column")}
                    class="inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 p-1.5 bg-base-100/90 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-md transition-all shadow-sm opacity-100 md:opacity-0 md:group-hover:opacity-100 md:group-focus-within:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                  >
                    <.icon
                      name="hero-pencil-solid"
                      class="h-4 w-4 text-base-content opacity-50 hover:text-blue-600 transition-colors"
                    />
                  </.link>
                  <.link
                    phx-click={JS.push("delete_column", value: %{id: column.id})}
                    data-confirm={
                      gettext(
                        "Are you sure you want to delete this column? All tasks in this column will also be deleted."
                      )
                    }
                    aria-label={gettext("Delete column")}
                    class="inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 p-1.5 bg-base-100/90 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-md transition-all shadow-sm phx-submit-loading:opacity-50 phx-submit-loading:cursor-wait opacity-100 md:opacity-0 md:group-hover:opacity-100 md:group-focus-within:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                  >
                    <.icon
                      name="hero-trash-solid"
                      class="h-4 w-4 text-base-content opacity-50 hover:text-red-600 transition-colors phx-submit-loading:animate-pulse"
                    />
                  </.link>
                </div>
              <% end %>
            </div>

            <div
              class="space-y-2 min-h-[100px] p-1 rounded transition-colors"
              id={"tasks-#{column.id}"}
              phx-hook="Sortable"
              data-column-id={column.id}
              data-version={@tasks_version}
              data-group="tasks"
              data-handle=".drag-handle"
              data-wip-limit={column.wip_limit}
              data-task-count={task_count}
              data-server-sorted={if column.name == "Done", do: "true"}
            >
              <div
                id={"empty-state-#{column.id}"}
                class={"empty-state #{if total_tasks > 0, do: "hidden"}"}
              >
                <ColumnEmpty.column_empty status={column_status(column.name)} />
              </div>

              <div
                :for={task <- Map.get(@tasks_by_column, column.id, [])}
                id={"task-#{task.id}"}
                data-id={task.id}
                data-position={task.position}
                class="group relative"
              >
                <div
                  :if={@can_modify}
                  class="absolute top-1 right-1 flex gap-1 opacity-100 md:opacity-0 md:group-hover:opacity-100 md:group-focus-within:opacity-100 transition-opacity z-10"
                >
                  <.link
                    patch={~p"/boards/#{@board}/tasks/#{task}/edit"}
                    aria-label={gettext("Edit task")}
                    class="inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 p-1 rounded hover:bg-base-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                  >
                    <.icon
                      name="hero-pencil-square"
                      class="h-3.5 w-3.5 text-base-content opacity-60"
                    />
                  </.link>
                  <button
                    type="button"
                    phx-click="archive_task"
                    phx-value-id={task.id}
                    aria-label={gettext("Archive task")}
                    class="inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 p-1 rounded hover:bg-base-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                  >
                    <.icon
                      name="hero-archive-box"
                      class="h-3.5 w-3.5 text-base-content opacity-60"
                    />
                  </button>
                  <button
                    type="button"
                    phx-click="delete_task"
                    phx-value-id={task.id}
                    data-confirm={gettext("Are you sure you want to delete this task?")}
                    aria-label={gettext("Delete task")}
                    class="inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 p-1 rounded hover:bg-red-50 text-red-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                  >
                    <.icon name="hero-trash" class="h-3.5 w-3.5" />
                  </button>
                </div>

                <div
                  :if={@can_modify and task.type != :goal}
                  class="drag-handle absolute top-1 left-1 inline-flex items-center justify-center min-h-11 min-w-11 md:min-h-0 md:min-w-0 opacity-40 md:opacity-0 md:group-hover:opacity-100 cursor-grab z-10"
                  aria-label={gettext("Drag to reorder")}
                >
                  <.icon name="hero-bars-3" class="h-3 w-3 text-base-content opacity-50" />
                </div>

                <div
                  phx-click="view_task"
                  phx-value-id={task.id}
                  class="cursor-pointer"
                >
                  <TaskCard.task_card
                    task={
                      task_card_data(
                        task,
                        @backlog_goals_with_children,
                        @goal_progress,
                        @goals_by_id
                      )
                    }
                    column={column_status(column.name)}
                    board_id={@board.id}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <KanbanWeb.DelayedModal.delayed_modal
    :if={@live_action in [:new_column, :edit_column]}
    id="column-modal"
    show
    on_cancel={JS.patch(~p"/boards/#{@board}")}
  >
    <.live_component
      module={KanbanWeb.ColumnLive.FormComponent}
      id={(@live_action == :new_column && :new) || "edit-#{@column.id}"}
      title={@page_title}
      action={@live_action}
      board={@board}
      column={(@live_action == :edit_column && @column) || %Kanban.Columns.Column{}}
      patch={~p"/boards/#{@board}"}
    />
  </KanbanWeb.DelayedModal.delayed_modal>

  <KanbanWeb.DelayedModal.delayed_modal
    :if={@live_action in [:new_task, :edit_task, :edit_task_in_column]}
    id="task-modal"
    show
    on_cancel={JS.patch(~p"/boards/#{@board}")}
    max_width="max-w-6xl"
    padding="p-6 sm:p-8"
  >
    <.live_component
      module={KanbanWeb.TaskLive.FormComponent}
      id={(@live_action == :new_task && :new) || "edit-#{@task.id}"}
      title={(@live_action == :new_task && "New Task") || "Edit Task"}
      action={@live_action}
      board={@board}
      task={(@live_action in [:edit_task, :edit_task_in_column] && @task) || %Kanban.Tasks.Task{}}
      column_id={(@live_action == :new_task && Map.get(assigns, :column_id)) || nil}
      current_scope={@current_scope}
      patch={~p"/boards/#{@board}"}
    />
  </KanbanWeb.DelayedModal.delayed_modal>

  <KanbanWeb.DelayedModal.delayed_modal
    :if={@live_action == :board_settings}
    id="board-settings-modal"
    show
    on_cancel={JS.patch(~p"/boards/#{@board}")}
  >
    <div class="stride-screen" style="margin-bottom: 14px;">
      <h2 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em;">
        {gettext("Board settings")}
      </h2>
      <p style="margin: 4px 0 0; font-size: 12.5px; color: var(--ink-3); line-height: 1.5;">
        {gettext("Update board details and choose which task fields appear on cards.")}
      </p>
    </div>
    <.live_component
      module={KanbanWeb.BoardLive.SettingsFormComponent}
      id={"board-settings-#{@board.id}"}
      board={@board}
      current_scope={@current_scope}
      patch={~p"/boards/#{@board}"}
    />
  </KanbanWeb.DelayedModal.delayed_modal>

  <KanbanWeb.DelayedModal.delayed_modal
    :if={@live_action == :manage_members}
    id="board-members-modal"
    show
    on_cancel={JS.patch(~p"/boards/#{@board}")}
  >
    <div class="stride-screen" style="margin-bottom: 14px;">
      <h2 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em;">
        {gettext("Manage members")}
      </h2>
      <p style="margin: 4px 0 0; font-size: 12.5px; color: var(--ink-3); line-height: 1.5;">
        {gettext("Invite registered users and control their access to this board.")}
      </p>
    </div>
    <.live_component
      module={KanbanWeb.BoardLive.MembersFormComponent}
      id={"board-members-#{@board.id}"}
      board={@board}
      current_scope={@current_scope}
      patch={~p"/boards/#{@board}"}
    />
  </KanbanWeb.DelayedModal.delayed_modal>

  <div :if={@viewing_task_id && @show_task_modal} id={"task-modal-wrapper-#{@viewing_task_id}"}>
    <KanbanWeb.DelayedModal.delayed_modal
      id="task-view-modal"
      show
      on_cancel={JS.push("close_task_view")}
      max_width="max-w-6xl"
      padding="p-6 sm:p-8"
    >
      <.live_component
        module={KanbanWeb.TaskLive.ViewComponent}
        id={"view-task-#{@viewing_task_id}"}
        task_id={@viewing_task_id}
        board_id={@board.id}
        ai_optimized_board={@board.ai_optimized_board}
        can_modify={@can_modify}
        field_visibility={@field_visibility}
      />
    </KanbanWeb.DelayedModal.delayed_modal>
  </div>

  <%!-- API Tokens Modal --%>
  <.modal
    :if={@live_action == :api_tokens}
    id="api-tokens-modal"
    show
    on_cancel={JS.patch(~p"/boards/#{@board}")}
  >
    <div class="stride-screen">
      <div style="margin-bottom: 14px;">
        <h2 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em;">
          {gettext("API tokens")}
        </h2>
        <p style="margin: 4px 0 0; font-size: 12.5px; color: var(--ink-3); line-height: 1.5;">
          {gettext(
            "Bearer tokens that authenticate agents on %{board_name}. Rotating a token does not release in-flight claims — the old token remains valid for a 60-second grace window.",
            board_name: @board.name
          )}
        </p>
      </div>

      <section
        :if={@new_token}
        style={[
          "background: var(--stride-orange-soft); border: 1px solid var(--line);",
          "border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;",
          "display: flex; align-items: flex-start; gap: 12px;"
        ]}
      >
        <span style="color: var(--stride-orange-ink); display: inline-flex; margin-top: 2px;">
          <.icon name="hero-check-circle" class="w-5 h-5" />
        </span>
        <div style="flex: 1; min-width: 0;">
          <div style="font-size: 13px; font-weight: 600; color: var(--ink); letter-spacing: -0.005em;">
            {gettext("Token created")}
          </div>
          <p style="margin: 4px 0 0; font-size: 11.5px; color: var(--ink-3); line-height: 1.5;">
            {gettext("Copy it now — you won't be able to see it again.")}
          </p>
          <div style="display: flex; align-items: center; gap: 8px; margin-top: 10px;">
            <code
              id="new-token-value"
              style={[
                "flex: 1; padding: 6px 10px; border-radius: 5px;",
                "background: var(--surface); border: 1px solid var(--line-strong);",
                "color: var(--ink); font-family: var(--font-mono);",
                "font-size: 11.5px; word-break: break-all;"
              ]}
            >
              {@new_token}
            </code>
            <button
              type="button"
              data-token-value={@new_token}
              data-copy-text={gettext("Copy")}
              data-copied-text={"✓ " <> gettext("Copied!")}
              data-failed-msg={gettext("Failed to copy")}
              onclick="
                const text = this.getAttribute('data-token-value');
                const copiedText = this.getAttribute('data-copied-text');
                const copyText = this.getAttribute('data-copy-text');
                const failedMsg = this.getAttribute('data-failed-msg');
                const textarea = document.createElement('textarea');
                textarea.value = text;
                textarea.style.position = 'fixed';
                textarea.style.opacity = '0';
                document.body.appendChild(textarea);
                textarea.select();
                try {
                  document.execCommand('copy');
                  this.innerHTML = copiedText;
                  setTimeout(() => { this.innerHTML = copyText; }, 2000);
                } catch (err) {
                  alert(failedMsg + ': ' + err.message);
                } finally {
                  document.body.removeChild(textarea);
                }
              "
              style={[
                "padding: 6px 12px; border-radius: 5px; border: none;",
                "background: var(--ink); color: white;",
                "font-size: 12px; font-weight: 500; cursor: pointer;"
              ]}
            >
              {gettext("Copy")}
            </button>
          </div>
        </div>
        <button
          type="button"
          phx-click="dismiss_token"
          aria-label={gettext("Dismiss")}
          style={[
            "padding: 4px; border-radius: 4px; border: none;",
            "background: transparent; cursor: pointer; color: var(--ink-3);"
          ]}
        >
          <.icon name="hero-x-mark" class="w-4 h-4" />
        </button>
      </section>

      <section style={[
        "background: var(--surface); border: 1px solid var(--line);",
        "border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;"
      ]}>
        <div style="margin-bottom: 12px;">
          <h3 style="margin: 0; font-size: 13px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em;">
            {gettext("Create new token")}
          </h3>
        </div>

        <.form
          for={@token_form}
          phx-submit="create_token"
          style="display: flex; flex-direction: column; gap: 12px;"
        >
          <label style="display: flex; flex-direction: column; gap: 5px;">
            <span class="ucase" style="font-size: 10.5px; color: var(--ink-3);">
              {gettext("Token name")}
            </span>
            <input
              id={@token_form[:name].id}
              name={@token_form[:name].name}
              type="text"
              required
              value={Phoenix.HTML.Form.normalize_value("text", @token_form[:name].value)}
              placeholder={gettext("My AI Agent")}
              style="height: 32px; padding: 0 10px; border-radius: 5px; background: var(--surface); color: var(--ink); border: 1px solid var(--line-strong); font-size: 12.5px;"
            />
            <span
              :for={msg <- Enum.map(@token_form[:name].errors, &translate_error(&1))}
              style="font-size: 11px; color: var(--st-blocked);"
            >
              {msg}
            </span>
          </label>

          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <label style="flex: 1 1 200px; display: flex; flex-direction: column; gap: 5px;">
              <span class="ucase" style="font-size: 10.5px; color: var(--ink-3);">
                {gettext("Agent model (optional)")}
              </span>
              <input
                id={@token_form[:agent_model].id}
                name={@token_form[:agent_model].name}
                type="text"
                placeholder={gettext("claude-4.5-opus")}
                style="height: 32px; padding: 0 10px; border-radius: 5px; background: var(--surface); color: var(--ink); border: 1px solid var(--line-strong); font-size: 12.5px;"
              />
            </label>

            <label style="flex: 1 1 200px; display: flex; flex-direction: column; gap: 5px;">
              <span class="ucase" style="font-size: 10.5px; color: var(--ink-3);">
                {gettext("Purpose (optional)")}
              </span>
              <input
                id={@token_form[:agent_purpose].id}
                name={@token_form[:agent_purpose].name}
                type="text"
                placeholder={gettext("Task automation")}
                style="height: 32px; padding: 0 10px; border-radius: 5px; background: var(--surface); color: var(--ink); border: 1px solid var(--line-strong); font-size: 12.5px;"
              />
            </label>
          </div>

          <label style="display: flex; flex-direction: column; gap: 5px;">
            <span class="ucase" style="font-size: 10.5px; color: var(--ink-3);">
              {gettext("Agent capabilities")}
            </span>
            <input
              id={@token_form[:agent_capabilities].id}
              name={@token_form[:agent_capabilities].name}
              type="text"
              placeholder={gettext("code_generation, testing, documentation")}
              phx-debounce="blur"
              style="height: 32px; padding: 0 10px; border-radius: 5px; background: var(--surface); color: var(--ink); border: 1px solid var(--line-strong); font-size: 12.5px;"
            />
            <span style="font-size: 11px; color: var(--ink-3); line-height: 1.5; text-wrap: pretty;">
              {gettext(
                "Comma-separated. Valid: api_design, code_generation, code_review, database_design, debugging, devops, documentation, file_operations, git, performance_optimization, refactoring, security_analysis, testing, ui_design, ui_implementation, web_browsing. Leave empty to allow all tasks."
              )}
            </span>
          </label>

          <div style="display: flex; justify-content: flex-end;">
            <button
              type="submit"
              phx-disable-with={gettext("Creating...")}
              style={[
                "padding: 6px 12px; border-radius: 5px; border: none;",
                "background: var(--ink); color: white;",
                "font-size: 12px; font-weight: 500; cursor: pointer;",
                "box-shadow: 0 1px 0 rgba(255,255,255,.1) inset, 0 1px 2px rgba(0,0,0,.2);"
              ]}
            >
              {gettext("Generate token")}
            </button>
          </div>
        </.form>
      </section>

      <section>
        <div class="ucase" style="font-size: 10.5px; color: var(--ink-3); margin-bottom: 8px;">
          {gettext("Active tokens")}
        </div>

        <%= if Enum.empty?(@api_tokens) do %>
          <p style={[
            "margin: 0; padding: 18px 16px;",
            "background: var(--surface); border: 1px solid var(--line); border-radius: 10px;",
            "font-size: 12.5px; color: var(--ink-3); line-height: 1.5;"
          ]}>
            {gettext("No API tokens yet. Generate one above to get started.")}
          </p>
        <% else %>
          <div style={[
            "background: var(--surface); border: 1px solid var(--line);",
            "border-radius: 10px; overflow: hidden;",
            "display: flex; flex-direction: column;"
          ]}>
            <div
              :for={{token, idx} <- Enum.with_index(@api_tokens)}
              style={[
                "display: flex; align-items: center; gap: 12px;",
                "padding: 12px 14px;",
                if(idx > 0, do: "border-top: 1px solid var(--line);", else: ""),
                if(token.revoked_at, do: "opacity: 0.55;", else: "")
              ]}
            >
              <span style={[
                "width: 28px; height: 28px; border-radius: 6px;",
                "background: var(--surface-sunken); color: var(--ink-3);",
                "display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;"
              ]}>
                <.icon name="hero-key" class="w-4 h-4" />
              </span>

              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; align-items: center; gap: 6px;">
                  <span style="font-size: 13px; font-weight: 600; color: var(--ink); letter-spacing: -0.005em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {token.name}
                  </span>
                  <span
                    :if={token.agent_model}
                    class="ident"
                    style="font-size: 10.5px;"
                  >
                    {token.agent_model}
                  </span>
                  <span
                    :if={token.revoked_at}
                    class="ucase"
                    style={[
                      "padding: 2px 6px; border-radius: 999px;",
                      "background: var(--st-blocked-soft); color: var(--st-blocked);",
                      "font-size: 9px; font-weight: 600; letter-spacing: 0.04em;"
                    ]}
                  >
                    {gettext("revoked")}
                  </span>
                </div>
                <div style="margin-top: 2px; font-size: 11.5px; color: var(--ink-3); font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {token.user.email}
                </div>
              </div>

              <div style="font-size: 11.5px; color: var(--ink-3); white-space: nowrap;">
                <%= if token.last_used_at do %>
                  <span class="ident">
                    {Calendar.strftime(token.last_used_at, "%Y-%m-%d %H:%M")}
                  </span>
                <% else %>
                  <span style="color: var(--ink-4);">{gettext("Never used")}</span>
                <% end %>
              </div>

              <%= if is_nil(token.revoked_at) do %>
                <button
                  type="button"
                  phx-click="revoke_token"
                  phx-value-id={token.id}
                  data-confirm={gettext("Are you sure you want to revoke this token?")}
                  style={[
                    "padding: 4px 10px; border-radius: 4px;",
                    "background: transparent; border: 1px solid var(--st-blocked);",
                    "color: var(--st-blocked); font-size: 11.5px; font-weight: 500;",
                    "cursor: pointer;"
                  ]}
                >
                  {gettext("Revoke")}
                </button>
              <% else %>
                <button
                  type="button"
                  phx-click="delete_token"
                  phx-value-id={token.id}
                  data-confirm={gettext("Are you sure you want to delete this token?")}
                  style={[
                    "padding: 4px 10px; border-radius: 4px;",
                    "background: transparent; border: 1px solid var(--line-strong);",
                    "color: var(--ink-2); font-size: 11.5px; font-weight: 500;",
                    "cursor: pointer;"
                  ]}
                >
                  {gettext("Delete")}
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>
    </div>
  </.modal>
</Layouts.app>
