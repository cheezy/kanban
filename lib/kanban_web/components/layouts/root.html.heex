<!DOCTYPE html>
<html lang={Gettext.get_locale(KanbanWeb.Gettext)} class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default={gettext("Stride")} suffix={gettext(" · Task Management")}>
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/svg+xml" href={~p"/images/favicon.svg"} />
    <link rel="icon" type="image/svg+xml" sizes="16x16" href={~p"/images/favicon-16x16.svg"} />
    <link rel="icon" type="image/svg+xml" sizes="32x32" href={~p"/images/favicon-32x32.svg"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/apple-touch-icon.svg"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js"}
      nonce={assigns[:csp_nonce]}
    >
    </script>
    <script nonce={assigns[:csp_nonce]}>
      (() => {
        const mql = window.matchMedia("(prefers-color-scheme: dark)");
        // Resolve a user choice ("system" | "light" | "dark") to a concrete theme.
        const resolve = (choice) =>
          choice === "light" || choice === "dark" ? choice : mql.matches ? "dark" : "light";
        // Paint only. data-theme drives the CSS — BOTH daisyUI and the Stride
        // :where([data-theme=dark]) override (which has no prefers-color-scheme
        // fallback), so we always set a concrete value. data-theme-choice drives
        // the 3-way toggle indicator so "system" still reads as system.
        const render = (choice) => {
          const el = document.documentElement;
          el.setAttribute("data-theme", resolve(choice));
          el.setAttribute("data-theme-choice", choice);
        };
        // Persist the user's choice, then paint. Absent phx:theme means system.
        const apply = (choice) => {
          if (choice === "light" || choice === "dark") {
            localStorage.setItem("phx:theme", choice);
          } else {
            localStorage.removeItem("phx:theme");
            choice = "system";
          }
          render(choice);
        };
        render(localStorage.getItem("phx:theme") || "system");
        window.addEventListener("phx:set-theme", (e) => apply(e.target.dataset.phxTheme));
        window.addEventListener("storage", (e) => e.key === "phx:theme" && render(e.newValue || "system"));
        mql.addEventListener("change", () => render(localStorage.getItem("phx:theme") || "system"));
      })();
    </script>
  </head>
  <body class="h-full bg-base-100">
    <div
      class="phx-loading-bar fixed top-0 left-0 right-0 h-1 z-50 transition-all duration-200 opacity-0"
      style="width: 0%; background: var(--loading-bar-gradient);"
    >
    </div>
    <nav class="bg-base-100 border-b border-base-300 shadow-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 justify-between items-center">
          <.logo brand_text={gettext("Stride")} />

          <div class="flex items-center gap-2 md:gap-4">
            <div class="hidden md:flex items-center gap-4">
              <%= if @current_scope do %>
                <.user_badge email={@current_scope.user.email} />
                <%= if @current_scope.user.type == :admin do %>
                  <.nav_link href={~p"/admin/dashboard"}>
                    {gettext("Dashboard")}
                  </.nav_link>
                  <.nav_link href={~p"/admin/errors"}>
                    {gettext("Error Tracker")}
                  </.nav_link>
                <% end %>
                <.nav_link href={~p"/boards"}>
                  {gettext("My Boards")}
                </.nav_link>
                <.nav_link href={~p"/users/settings"}>
                  {gettext("Settings")}
                </.nav_link>
                <.nav_link href={~p"/resources"}>
                  {gettext("Resources")}
                </.nav_link>
                <.nav_link href={~p"/about"}>
                  {gettext("About")}
                </.nav_link>
                <.nav_btn_primary href={~p"/users/log-out"} method="delete">
                  {gettext("Log out")}
                </.nav_btn_primary>
              <% else %>
                <.nav_link href={~p"/resources"}>
                  {gettext("Resources")}
                </.nav_link>
                <.nav_link href={~p"/about"}>
                  {gettext("About")}
                </.nav_link>
                <.nav_link href={~p"/users/log-in"}>
                  {gettext("Log in")}
                </.nav_link>
                <.nav_btn_secondary href={~p"/users/register"}>
                  {gettext("Get Started")}
                </.nav_btn_secondary>
              <% end %>
            </div>

            <.language_switcher current_locale={Gettext.get_locale(KanbanWeb.Gettext)} />

            <.mobile_menu current_scope={@current_scope} />
          </div>
        </div>
      </div>
    </nav>

    {@inner_content}
  </body>
</html>
