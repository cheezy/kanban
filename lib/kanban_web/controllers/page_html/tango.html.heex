<Layouts.app flash={@flash} current_scope={@current_scope} active={:about}>
  <:breadcrumbs>
    <.link
      navigate={~p"/about"}
      style="color: var(--ink-3); text-decoration: none;"
    >
      {gettext("About")}
    </.link>
    <span style="color: var(--ink-4); margin: 0 6px;">/</span>
    <span style="color: var(--ink); font-weight: 500;">{gettext("Tango")}</span>
  </:breadcrumbs>

  <div class="flex flex-col py-[18px]" data-tango>
    <header class="px-7 pb-[18px] flex flex-col gap-3 max-w-3xl">
      <div>
        <.link
          href={~p"/about"}
          class="inline-flex items-center gap-1 text-[12.5px] font-medium"
          style="color: var(--stride-orange); text-decoration: none;"
        >
          <.icon name="hero-arrow-left" class="h-3 w-3" />
          {gettext("Back to About")}
        </.link>
      </div>

      <h1
        class="m-0 text-[18px] font-semibold tracking-tight"
        style="color: var(--ink);"
      >
        {gettext("About Tango")}
      </h1>
      <p
        class="m-0 text-[12.5px] font-mono"
        style="color: var(--ink-3);"
      >
        {gettext("The people and the AI collaborator behind Stride.")}
      </p>
    </header>

    <div class="px-7 pt-[18px] pb-7 flex flex-col gap-[18px] max-w-3xl">
      <section
        class="flex flex-col gap-3 p-[18px]"
        style={[
          "background: var(--surface);",
          "border: 1px solid var(--line);",
          "border-radius: var(--r-lg);",
          "box-shadow: var(--shadow-sm);"
        ]}
      >
        <h2
          class="m-0 text-[14px] font-semibold tracking-tight"
          style="color: var(--ink);"
        >
          {gettext("The People Behind This App")}
        </h2>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext("This application was created by")}
          <strong style="color: var(--ink); font-weight: 600;">Tango</strong>{gettext(
            ", together with our AI-powered virtual team member,"
          )}
          <strong style="color: var(--ink); font-weight: 600;">Claudete</strong>.
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "Tango is a Canada-based software company focused on building modern, scalable digital products by combining cutting-edge technology with AI-assisted development. We help organizations move faster, build smarter, and deliver higher-quality software without unnecessary complexity."
          )}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          <strong style="color: var(--ink); font-weight: 600;">Claudete</strong>
          {gettext("was born from our hands-on work with two AI tools —")}
          <strong style="color: var(--ink); font-weight: 600;">Claude Code</strong>
          {gettext("and")}
          <strong style="color: var(--ink); font-weight: 600;">Tidewave</strong>{gettext(
            ". Their combined strengths evolved into a collaborative virtual team member that works alongside our developers, accelerating delivery while maintaining precision and quality."
          )}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "What began as an internal learning journey—exploring the real-world potential of AI-assisted development—quickly became something more. As we experienced the impact firsthand, we realized how powerful it is to put AI directly into the hands of experienced engineers. The results reshaped how we think about software delivery."
          )}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "We saw possibilities not just for startups, but for development teams of any size—across private and public sectors, and in virtually any industry."
          )}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "While many large organizations attempt to improve outcomes by measuring productivity, our experience shows that true gains come from"
          )}
          <em style="color: var(--ink); font-style: italic;">{gettext("speed")}</em>,
          <em style="color: var(--ink); font-style: italic;">{gettext("accuracy")}</em>,
          {gettext("and")}
          <em style="color: var(--ink); font-style: italic;">{gettext("quality")}</em>{gettext(
            ". With AI as a true collaborator, those metrics are no longer incremental—they're transformed."
          )}
        </p>
      </section>

      <section
        class="flex flex-col gap-3 p-[18px]"
        style={[
          "background: var(--surface);",
          "border: 1px solid var(--line);",
          "border-radius: var(--r-lg);",
          "box-shadow: var(--shadow-sm);"
        ]}
      >
        <h2
          class="m-0 text-[14px] font-semibold tracking-tight"
          style="color: var(--ink);"
        >
          {gettext("Our Mission")}
        </h2>
        <p
          class="m-0 text-[14px] font-semibold leading-relaxed"
          style="color: var(--ink);"
        >
          {gettext("Build what's next. Together.")}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "AI-powered development, seasoned engineers, and technical coaching for modern software teams."
          )}
        </p>
      </section>

      <section
        class="flex flex-col gap-3 p-[18px]"
        style={[
          "background: var(--surface);",
          "border: 1px solid var(--line);",
          "border-radius: var(--r-lg);",
          "box-shadow: var(--shadow-sm);"
        ]}
      >
        <h2
          class="m-0 text-[14px] font-semibold tracking-tight"
          style="color: var(--ink);"
        >
          {gettext("Work With Us")}
        </h2>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "At Tango, we don't just build products — we help teams rethink how software gets delivered in an AI-first world."
          )}
        </p>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "Whether you're exploring AI-assisted development, modernizing existing systems, or building something entirely new, we partner closely with your team to turn ideas into high-quality, production-ready solutions. Our approach blends experienced engineers with AI-powered workflows to deliver results faster, with greater accuracy and long-term maintainability."
          )}
        </p>
        <p
          class="m-0 text-[12.5px] font-mono uppercase tracking-wide"
          style="color: var(--ink-3);"
        >
          {gettext("We work with")}
        </p>
        <ul class="m-0 p-0 list-none flex flex-col gap-2">
          <li class="text-[13px] leading-relaxed" style="color: var(--ink-2);">
            {gettext("Startups looking to move fast without sacrificing quality.")}
          </li>
          <li class="text-[13px] leading-relaxed" style="color: var(--ink-2);">
            {gettext("Established companies modernizing their development practices.")}
          </li>
          <li class="text-[13px] leading-relaxed" style="color: var(--ink-2);">
            {gettext("Public and private sector teams tackling complex technical challenges.")}
          </li>
        </ul>
        <p class="m-0 text-[13px] leading-relaxed" style="color: var(--ink-2);">
          {gettext(
            "If you're curious about how AI can elevate your development process — or you need a trusted partner to help build, scale, or innovate — we'd love to collaborate."
          )}
        </p>
        <p
          class="m-0 text-[14px] font-semibold leading-relaxed"
          style="color: var(--ink);"
        >
          {gettext("Let's build what's next, together.")}
        </p>
      </section>

      <div class="pt-[18px]" style="border-top: 1px solid var(--line);">
        <.link
          href={~p"/about"}
          class="inline-flex items-center gap-1.5 text-[12.5px] font-medium"
          style="color: var(--stride-orange); text-decoration: none;"
        >
          <.icon name="hero-arrow-left" class="w-3 h-3" />
          {gettext("Back to About")}
        </.link>
      </div>
    </div>
  </div>
</Layouts.app>
